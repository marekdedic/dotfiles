[alias]
	s = status
	d = difftool --dir-diff
	a = add --all
	ds = difftool --dir-diff --staged
	c = commit -m
	ap = add --all -p
	b = branch -vv
	tree-sha1 = log --pretty=format:'%T %s'
	r = remote -v
	autorebase = "!git rebase --interactive --autosquash $(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||' || git config init.defaultBranch || echo master)"
	fixup = "!git commit --fixup $(git log --format='%h %ad %<(15,trunc)%an %s' --date=short | fzf --no-sort | cut -d' ' -f1)"
[commit]
	gpgsign = true
[diff]
	tool = meld
	algorithm = histogram
[merge]
	tool = meld
	conflictStyle = zdiff3
[user]
	name = Marek Dědič
	signingkey = C23EEA30!
	email = developer@dedic.eu
[pull]
	rebase = false
[init]
	defaultBranch = master
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[push]
	autoSetupRemote = true
[tag]
	gpgSign = true
[rerere]
	enabled = true
