{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "autoupdate": true,
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "awk *": "allow",
      "cat *": "allow",
      "cd *": "allow",
      "find *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "latexmk *": "allow",
      "ls *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "which *": "allow"
    },
    "edit": {
      "*": "allow",
      ".*": "ask",
      "*.env": "ask",
      "*.env.*": "ask"
    },
    "glob": "allow",
    "grep": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask"
    },
    "list": "allow",
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask"
    },
    "todoread": "allow",
    "todowrite": "allow",
    "write": {
      "*": "allow",
      ".*": "ask",
      "*.env": "ask",
      "*.env.*": "ask"
    },
  }
}
